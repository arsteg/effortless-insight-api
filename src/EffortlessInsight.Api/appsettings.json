{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=effortlessinsight;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Secret": "your-super-secret-jwt-key-change-in-production-min-32-chars",
    "Issuer": "effortlessinsight",
    "Audience": "effortlessinsight-api",
    "ExpiryMinutes": 15,
    "RefreshExpiryDays": 7
  },
  "AiService": {
    "BaseUrl": "http://localhost:8000"
  },
  "AWS": {
    "Region": "ap-south-1",
    "S3": {
      "BucketName": "effortlessinsight-uploads",
      "ReportsBucket": "effortlessinsight-reports"
    }
  },
  "Cors": {
    "Origins": [
      "http://localhost:3000",
      "http://localhost:8081"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
