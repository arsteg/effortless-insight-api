{
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_URL}",
    "Redis": "${REDIS_URL}"
  },
  "App": {
    "BaseUrl": "${APP_BASE_URL}"
  },
  "Jwt": {
    "RsaPrivateKey": "${JWT_RSA_PRIVATE_KEY}",
    "RsaPublicKey": "${JWT_RSA_PUBLIC_KEY}",
    "UseAsymmetricSigning": true,
    "Issuer": "effortlessinsight",
    "Audience": "effortlessinsight-api",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7,
    "RememberMeRefreshTokenExpiryDays": 30
  },
  "OAuth": {
    "Google": {
      "ClientId": "${GOOGLE_CLIENT_ID}",
      "ClientSecret": "${GOOGLE_CLIENT_SECRET}",
      "Enabled": true
    },
    "Microsoft": {
      "ClientId": "${MICROSOFT_CLIENT_ID}",
      "ClientSecret": "${MICROSOFT_CLIENT_SECRET}",
      "Enabled": true
    },
    "CallbackBaseUrl": "${OAUTH_CALLBACK_BASE_URL}"
  },
  "TwoFactor": {
    "Issuer": "EffortlessInsight",
    "EncryptionKey": "${TOTP_ENCRYPTION_KEY}"
  },
  "Sms": {
    "Provider": "twilio",
    "TwilioAccountSid": "${TWILIO_ACCOUNT_SID}",
    "TwilioAuthToken": "${TWILIO_AUTH_TOKEN}",
    "TwilioFromNumber": "${TWILIO_FROM_NUMBER}"
  },
  "Resend": {
    "ApiKey": "${RESEND_API_KEY}",
    "FromEmail": "${EMAIL_FROM_ADDRESS}",
    "FromName": "EffortlessInsight"
  },
  "Twilio": {
    "AccountSid": "${TWILIO_ACCOUNT_SID}",
    "AuthToken": "${TWILIO_AUTH_TOKEN}",
    "SmsFromNumber": "${TWILIO_SMS_FROM_NUMBER}",
    "WhatsAppFromNumber": "${TWILIO_WHATSAPP_FROM_NUMBER}",
    "StatusCallbackUrl": "${TWILIO_STATUS_CALLBACK_URL}"
  },
  "Firebase": {
    "ProjectId": "${FIREBASE_PROJECT_ID}",
    "PrivateKey": "${FIREBASE_PRIVATE_KEY}",
    "ClientEmail": "${FIREBASE_CLIENT_EMAIL}"
  },
  "AiService": {
    "BaseUrl": "${AI_SERVICE_URL}",
    "ApiKey": "${AI_SERVICE_API_KEY}"
  },
  "AWS": {
    "Region": "ap-south-1",
    "S3": {
      "BucketName": "${AWS_S3_BUCKET_NAME}",
      "ReportsBucket": "${AWS_S3_REPORTS_BUCKET}"
    }
  },
  "Razorpay": {
    "KeyId": "${RAZORPAY_KEY_ID}",
    "KeySecret": "${RAZORPAY_KEY_SECRET}",
    "WebhookSecret": "${RAZORPAY_WEBHOOK_SECRET}",
    "TestMode": false
  },
  "Sentry": {
    "Dsn": "${SENTRY_DSN}"
  },
  "DataRetention": {
    "NoticeRetentionDays": 2920,
    "AttachmentRetentionDays": 2920,
    "CommentRetentionDays": 2920,
    "TaskRetentionDays": 2920,
    "AuditLogRetentionDays": 365,
    "LoginAuditRetentionDays": 180,
    "ExpiredSessionRetentionDays": 30,
    "BatchSize": 1000,
    "Enabled": true,
    "DeleteFilesFromStorage": false
  },
  "AdminAuth": {
    "JwtSecret": "${ADMIN_JWT_SECRET}",
    "JwtIssuer": "EffortlessInsight-Admin",
    "JwtAudience": "EffortlessInsight-Admin-Portal",
    "MfaEncryptionKey": "${ADMIN_MFA_ENCRYPTION_KEY}",
    "RequireMfa": true
  },
  "Cors": {
    "Origins": ["${CORS_ALLOWED_ORIGINS}"]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
