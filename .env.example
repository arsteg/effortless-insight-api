# EffortlessInsight API - Environment Variables Template
# Copy this file to .env and fill in the values for your environment
# NEVER commit .env files with real secrets to version control

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=Host=localhost;Port=5432;Database=effortlessinsight;Username=postgres;Password=your_password
REDIS_URL=localhost:6379

# =============================================================================
# APPLICATION
# =============================================================================
APP_BASE_URL=https://app.effortlessinsight.com
ASPNETCORE_ENVIRONMENT=Production

# =============================================================================
# JWT AUTHENTICATION (RS256)
# Generate RSA keys: openssl genrsa -out private.pem 2048
#                    openssl rsa -in private.pem -pubout -out public.pem
# =============================================================================
JWT_RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# =============================================================================
# OAUTH PROVIDERS
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OAUTH_CALLBACK_BASE_URL=https://app.effortlessinsight.com

# =============================================================================
# TWO-FACTOR AUTHENTICATION
# Generate: openssl rand -base64 32
# =============================================================================
TOTP_ENCRYPTION_KEY=

# =============================================================================
# EMAIL (Resend)
# =============================================================================
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=notifications@effortlessinsight.com

# =============================================================================
# SMS & WHATSAPP (Twilio)
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_SMS_FROM_NUMBER=
TWILIO_WHATSAPP_FROM_NUMBER=
TWILIO_STATUS_CALLBACK_URL=

# =============================================================================
# PUSH NOTIFICATIONS (Firebase)
# =============================================================================
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# =============================================================================
# AI SERVICE
# =============================================================================
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_API_KEY=

# =============================================================================
# AWS S3
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=effortlessinsight-uploads
AWS_S3_REPORTS_BUCKET=effortlessinsight-reports

# =============================================================================
# PAYMENTS (Razorpay)
# =============================================================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# =============================================================================
# ERROR TRACKING (Sentry)
# =============================================================================
SENTRY_DSN=

# =============================================================================
# ADMIN PORTAL
# Generate: openssl rand -base64 64
# =============================================================================
ADMIN_JWT_SECRET=
ADMIN_MFA_ENCRYPTION_KEY=

# =============================================================================
# FIELD-LEVEL ENCRYPTION
# Generate: openssl rand -base64 32
# Used for encrypting PII fields (GSTIN, PAN) at rest
# =============================================================================
FIELD_ENCRYPTION_KEY=

# =============================================================================
# CORS
# Comma-separated list of allowed origins
# =============================================================================
CORS_ALLOWED_ORIGINS=https://app.effortlessinsight.com,https://admin.effortlessinsight.com
